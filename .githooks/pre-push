#!/bin/sh

set -eu

if [ "${ALLOW_MAIN_PUSH:-}" = "1" ]; then
  exit 0
fi

blocked=0

while read -r local_ref local_sha remote_ref remote_sha
 do
  if [ "$remote_ref" = "refs/heads/main" ]; then
    blocked=1
    break
  fi
 done

if [ "$blocked" -eq 1 ]; then
  echo >&2
  echo >&2 "Push to main is blocked by local safety hook."
  echo >&2 "Create a branch and open a PR instead."
  echo >&2
  echo >&2 "Temporary override if you really intend to push to main:"
  echo >&2 "PowerShell: set ALLOW_MAIN_PUSH and run git push origin main"
  echo >&2 "bash: ALLOW_MAIN_PUSH=1 git push origin main"
  echo >&2
  exit 1
fi

exit 0
